{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "eslint",
    "typescript",
    "unicorn",
    "oxc",
    "react",
    "jsx-a11y",
    "nextjs",
    "import",
    "promise"
  ],
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off"
  },
  "options": {
    "typeAware": true,
    "typeCheck": true,
    "maxWarnings": 10
  },
  "rules": {
    "no-alert": "error",
    "no-console": "error",
    "no-plusplus": "off",
    "oxc/approx-constant": "warn",
    "eslint/prefer-const": ["error", { "destructuring": "any" }],
    "typescript/no-explicit-any": "error",
    "react/react-in-jsx-scope": "off"
  },
  "overrides": [
    {
      "files": ["**/*.test.{ts,tsx}", "tests/unit/**"],
      "plugins": ["vitest"],
      "env": { "vitest": true }
    }
  ]
}
